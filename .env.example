# PayPal API credentials
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret

# live or sandbox
PAYPAL_ENV=live
# optional override
# PAYPAL_API_BASE=https://api-m.sandbox.paypal.com

# Optional explicit success/cancel URLs; if omitted they are derived from origin sent by client
PAYWALL_SUCCESS_URL=https://kilby8.github.io/KJ/?paid=1
PAYWALL_CANCEL_URL=https://kilby8.github.io/KJ/?canceled=1

# Allowed CORS origin for paywall page
PAYWALL_ORIGIN=https://kilby8.github.io

# Default PayPal order amount/currency for API-created orders
PAYPAL_AMOUNT=29.00
PAYPAL_CURRENCY=USD

# File served after successful payment
DOWNLOAD_FILE_PATH=./release/IKFS-Setup.exe

# HMAC secret for signing short-lived download tokens
TOKEN_SECRET=replace-with-long-random-secret

# API port and token lifetime
PORT=8787
TOKEN_TTL_SECONDS=900

