{
  "name": "ironorr-karaoke-file-system-ikfs",
  "version": "1.0.4",
  "description": "A cross-platform karaoke file manager with batch tag editing, field shifting, and multi-format support.",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:vite\" \"npm run dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "wait-on http://localhost:5173 && electron .",
    "build": "vite build",
    "build:electron": "npm run build && electron-builder",
    "publish:electron": "npm run build && electron-builder --publish always",
    "test": "echo \"No tests configured yet\" && exit 0"
  },
  "keywords": [
    "karaoke",
    "file-manager",
    "mp3",
    "cdg",
    "electron"
  ],
  "author": "KJ",
  "license": "ISC",
  "build": {
    "appId": "com.ironorr.ikfs",
    "productName": "Ironorr-Karaoke-File-System (IKFS)",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "kilby8",
        "repo": "KJ",
        "releaseType": "release"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "public/icon.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "public/icon.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "public/icon.png"
    }
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "eslint": "^10.2.1",
    "vite": "^8.0.10",
    "wait-on": "^9.0.5"
  },
  "dependencies": {
    "adm-zip": "^0.5.17",
    "electron-updater": "^6.3.9",
    "music-metadata": "^11.12.3",
    "node-id3": "^0.2.9",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  }
}
